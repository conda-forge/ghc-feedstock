-- Cabal configuration options to help with HSC tool crashes
program-options
  -- Use more conservative GHC options for HSC tools
  ghc-options: -rtsopts -with-rtsopts=-K32M -fno-full-laziness

-- Package-specific configuration
package clock
  -- Set custom flags for the clock package
  flags: +llvm +force-o0
  -- More conservative compiler options for problematic packages
  ghc-options: -O0 -fno-omit-yields -fno-builtin -fno-stack-protector

