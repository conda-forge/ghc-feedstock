       ]
   , notStage0 ? platformSupportsSharedLibs ? targetSupportsThreadedRts ? pure [ threadedDynamic, threadedDebugDynamic ]
+  , notStage0 ? platformSupportsSharedLibs ? pure [ profilingDynamic, debugProfilingDynamic ]
+  , notStage0 ? platformSupportsSharedLibs ? targetSupportsThreadedRts ? pure [ threadedProfilingDynamic ]
   ]
