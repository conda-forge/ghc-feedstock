--- a/hadrian/cabal.project
+++ b/hadrian/cabal.project
@@ -1,9 +1,16 @@
 packages: ./
 
 -- This essentially freezes the build plan for hadrian
-index-state: 2025-01-08T09:21:31Z
+-- Use a more conservative index state to avoid tarball unpacking issues
+index-state: 2024-10-01T00:00:00Z
+
+-- Work around tarball structure issues with old Cabal versions
+allow-newer: *:*
+allow-older: *:*
 
 -- N.B. Compile with -O0 since this is not a performance-critical executable
 -- and the Cabal takes nearly twice as long to build with -O1. See #16817.
 package Cabal
   optimization: False
+
+write-ghc-environment-files: never