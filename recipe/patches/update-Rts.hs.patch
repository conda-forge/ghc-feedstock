--- a/hadrian/src/Rules/Rts.hs
+++ b/hadrian/src/Rules/Rts.hs
@@ -25,5 +25,21 @@ rtsRules = priority 3 $ do
             (addRtsDummyVersion $ takeFileName rtsLibFilePath')
             rtsLibFilePath'

+    -- Create static library symlinks for dynamic-only builds
+    [ root -/- "**/libHSrts-1.0.2.a",
+      root -/- "**/libHSrts-1.0.2_thr.a" ] |%> \ staticLibPath -> do
+        putProgressInfo $ "DEBUG: Creating symlink for " ++ staticLibPath
+        let dynamicLib = if "thr" `elem` words staticLibPath
+                        then "libHSrts-1.0.2_thr-ghc9.6.7.so"
+                        else "libHSrts-1.0.2-ghc9.6.7.so"
+        putProgressInfo $ "DEBUG: Linking " ++ staticLibPath ++ " -> " ++ dynamicLib
+        cmd "ln" ["-sf", dynamicLib, staticLibPath]
+
+    -- Force creation of .a symlinks when .so files exist (broader pattern)
+    [ root -/- "**/*rts*/**/libHSrts-*.a" ] |%> \ staticLibPath -> do
+        putProgressInfo $ "DEBUG: FALLBACK: Creating .a symlink via fallback rule"
+        let dynamicLib = if "thr" `elem` words staticLibPath then "libHSrts-1.0.2_thr-ghc9.6.7.so" else "libHSrts-1.0.2-ghc9.6.7.so"
+        cmd "ln" ["-sf", dynamicLib, staticLibPath]
+
     -- Libffi
     forM_ [Stage1, Stage2, Stage3 ] $ \ stage -> do
@@ -160,2 +174,7 @@ needRtsLibffiTargets stage = do
         need [removeRtsDummyVersion (libPath </> distDir </> rtsLibFile)]
+        putProgressInfo $ "DEBUG: needRtsSymLinks called for stage " ++ show stage
+        rtsPath <- rtsBuildPath stage
+        putProgressInfo $ "DEBUG: RTS path: " ++ rtsPath
+        need [ rtsPath -/- "libHSrts-1.0.2.a"
+             , rtsPath -/- "libHSrts-1.0.2_thr.a" ]
 
