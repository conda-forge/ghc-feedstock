+-- | For dynamic-only builds, duplicate .dyn_o entries as .o entries
+-- This ensures dependency tracking works when Hadrian expects .o files
+duplicateForDynamicOnly :: (String, [String]) -> [(String, [String])]
+duplicateForDynamicOnly entry@(target, deps)
+    | ".dyn_o" `isSuffixOf` target =
+        [ entry  -- Keep original .dyn_o entry
+        , (replaceExtension target "o", map convertDynDep deps)  -- Add .o entry
+        ]
+    | otherwise = [entry]
+  where
+    convertDynDep dep
+        | ".dyn_hi" `isSuffixOf` dep = replaceExtension dep "hi"
+        | otherwise = dep