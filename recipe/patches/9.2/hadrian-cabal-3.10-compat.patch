From: conda-forge
Subject: [PATCH] Add Cabal 3.10 compatibility for Hadrian

GHC 9.6.7 ships with Cabal 3.10 which removed the readGenericPackageDescription
and readHookedBuildInfo APIs. This patch adds conditional code using
MIN_VERSION_Cabal macros to use the new parseGenericPackageDescription and
parseHookedBuildInfo APIs when building with Cabal >= 3.8.0.

In Cabal 3.8+, these parse functions return Either instead of ParseResult:
- parseGenericPackageDescription :: ByteString -> Either (Maybe Version, NonEmpty PError) GenericPackageDescription
- parseHookedBuildInfo :: ByteString -> Either (Maybe Version, NonEmpty PError) HookedBuildInfo

This is required when using GHC 9.6.7 as bootstrap to build GHC 9.2.8.

--- a/hadrian/src/Hadrian/Haskell/Cabal/Parse.hs
+++ b/hadrian/src/Hadrian/Haskell/Cabal/Parse.hs
@@ -44,6 +44,9 @@
 #if !MIN_VERSION_Cabal(3,4,0)
 import qualified Distribution.Types.CondTree                   as C
 #endif
+#if MIN_VERSION_Cabal(3,8,0)
+import qualified Data.ByteString as BS
+#endif
 import qualified Distribution.Verbosity                        as C
 import Hadrian.Expression
 import Hadrian.Haskell.Cabal
@@ -64,7 +67,15 @@
 parsePackageData :: Package -> Action PackageData
 parsePackageData pkg = do
     gpd <- traced "cabal-read" $
+#if MIN_VERSION_Cabal(3,8,0)
+        do
+            contents <- liftIO $ BS.readFile (pkgCabalFile pkg)
+            case C.parseGenericPackageDescription contents of
+                Left err -> error $ "Failed to parse " ++ pkgCabalFile pkg ++ ": " ++ show err
+                Right gpd' -> return gpd'
+#else
         C.readGenericPackageDescription C.verbose (pkgCabalFile pkg)
+#endif
     let pd      = C.packageDescription gpd
         pkgId   = C.package pd
         name    = C.unPackageName (C.pkgName pkgId)
@@ -89,7 +100,15 @@

 -- | Parse the package identifier from a Cabal file.
 parseCabalPkgId :: FilePath -> IO String
+#if MIN_VERSION_Cabal(3,8,0)
+parseCabalPkgId file = do
+    contents <- BS.readFile file
+    case C.parseGenericPackageDescription contents of
+        Left err -> error $ "Failed to parse " ++ file ++ ": " ++ show err
+        Right gpd -> return $ C.display . C.package . C.packageDescription $ gpd
+#else
 parseCabalPkgId file = C.display . C.package . C.packageDescription <$> C.readGenericPackageDescription C.silent file
+#endif

 biModules :: C.PackageDescription -> (C.BuildInfo, [C.ModuleName], Maybe (C.ModuleName, String))
 biModules pd = go [ comp | comp@(bi,_,_) <-
@@ -315,7 +334,15 @@
     maybeInfoFile <- C.findHookedPackageDesc C.normal baseDir
     case maybeInfoFile of
         Nothing       -> getHookedBuildInfo baseDirs
+#if MIN_VERSION_Cabal(3,8,0)
+        Just infoFile -> do
+            contents <- BS.readFile infoFile
+            case C.parseHookedBuildInfo contents of
+                Left err -> error $ "Failed to parse " ++ infoFile ++ ": " ++ show err
+                Right hbi -> return hbi
+#else
         Just infoFile -> C.readHookedBuildInfo C.silent infoFile
+#endif

