From: conda-forge
Subject: [PATCH] Use gen-pkg-config + recache for Stage0 packages

When using a different bootstrap GHC version (e.g., 9.6.7 to build 9.2.8),
Cabal's register command doesn't reliably register packages to the Stage0
package database.

The fix: For Stage0:
1. Use 'cabal register --gen-pkg-config=<path>' to generate the .conf file
2. Run 'ghc-pkg recache' to update the package database cache

Just writing the .conf file is not enough - ghc-pkg needs to recache to
see the new package when Cabal.configurePackage queries for dependencies.

NOTE: This patch must be applied AFTER hadrian-cabal-3.10-compat.patch,
fix-hadrian-ghcpkg-copy-windows.patch, and fix-hadrian-configure-needs-conf.patch
as line numbers depend on those patches being applied first.

--- a/hadrian/src/Hadrian/Haskell/Cabal/Parse.hs
+++ b/hadrian/src/Hadrian/Haskell/Cabal/Parse.hs
@@ -11,7 +11,7 @@
 -----------------------------------------------------------------------------
 module Hadrian.Haskell.Cabal.Parse (
     parsePackageData, resolveContextData, parseCabalPkgId, configurePackage,
-    buildAutogenFiles, copyPackage, registerPackage
+    buildAutogenFiles, copyPackage, registerPackage, genPkgConfig
     ) where

 import Data.Bifunctor
@@ -214,6 +214,20 @@
     traced "cabal-register" $
         C.defaultMainWithHooksNoReadArgs C.autoconfUserHooks gpd
             [ "register", "--builddir", ctxPath, v ]
+
+-- | Generate a package config file for the 'Package' without registering.
+-- This is useful when we need to write the .conf file to a specific location.
+genPkgConfig :: Context -> FilePath -> Action ()
+genPkgConfig context@Context {..} confFile = do
+    putProgressInfo $ "| Generate pkg config " ++ quote (pkgName package)
+    ctxPath <- Context.contextPath context
+    gpd <- pkgGenericDescription package
+    verbosity <- getVerbosity
+    let v = if verbosity >= Loud then "-v3" else "-v0"
+    traced "cabal-gen-pkg-config" $
+        C.defaultMainWithHooksNoReadArgs C.autoconfUserHooks gpd
+            [ "register", "--builddir", ctxPath, "--gen-pkg-config=" ++ confFile, v ]
+
 -- | What type of file is Main
 data MainSourceType = HsMain | CppMain | CMain

--- a/hadrian/src/Rules/Register.hs
+++ b/hadrian/src/Rules/Register.hs
@@ -159,8 +159,26 @@
             need [path -/- "include/ghc-gmp.h"]

     -- Copy and register the package.
+    -- Note: For Stage0 with different bootstrap versions, Cabal.registerPackage
+    -- doesn't reliably register to the correct package database. We generate
+    -- the .conf file directly to the package db, then recache.
     Cabal.copyPackage context
-    Cabal.registerPackage context
+
+    case stage of
+        Stage0 -> do
+            -- Generate .conf file directly to the package database directory.
+            pkgDbPath <- packageDbPath stage
+            pkgId <- pkgIdentifier package
+            Cabal.genPkgConfig context (pkgDbPath -/- pkgId <.> "conf")
+            -- Recache the package database so ghc-pkg can see the new package.
+            -- This is required for subsequent Cabal.configurePackage calls.
+            ghcPkgPath <- builderPath (GhcPkg Init stage)
+            verbosity <- getVerbosity
+            let verbosityFlag = if verbosity < Chatty then ["-v0"] else []
+            cmd_ [ghcPkgPath] (["--no-user-package-db", "--global-package-db", pkgDbPath
+                              , "recache"] ++ verbosityFlag)
+        _ ->
+            Cabal.registerPackage context

     -- We declare that this rule also produces files matching:
     --   - <root>/stage<N>/lib/<arch>-<os>-ghc-<version>/*libHS<pkgid>*
