From: conda-forge
Subject: [PATCH] Relax version bounds for GHC 9.6.7 bootstrap compatibility

When using GHC 9.6.7 as bootstrap to build GHC 9.2.8, the bundled packages
have newer versions than the upper bounds in GHC 9.2.8's library cabal files:
- GHC 9.6.7 has base 4.18.x (libraries require < 4.17)
- GHC 9.6.7 has time 1.12.2 (libraries require < 1.12)

This patch relaxes the upper bounds to allow building with newer bootstrap GHC.

--- a/libraries/array/array.cabal
+++ b/libraries/array/array.cabal
@@ -31,7 +31,7 @@ source-repository head

 library
   default-language: Haskell2010
-  build-depends: base >= 4.9 && < 4.17
+  build-depends: base >= 4.9 && < 4.19
   exposed-modules:
       Data.Array
       Data.Array.Base

--- a/libraries/deepseq/deepseq.cabal
+++ b/libraries/deepseq/deepseq.cabal
@@ -37,7 +37,7 @@ library
   default-language:    Haskell2010
   other-extensions:    BangPatterns, CPP

-  build-depends: base       >= 4.5 && < 4.17,
+  build-depends: base       >= 4.5 && < 4.19,
                  array      >= 0.4 && < 0.6
   ghc-options: -Wall

--- a/libraries/directory/directory.cabal
+++ b/libraries/directory/directory.cabal
@@ -52,9 +52,9 @@ library
     default-language: Haskell2010
     other-extensions: CPP
     build-depends:
-        base     >= 4.5 && < 4.17,
+        base     >= 4.5 && < 4.19,
         filepath >= 1.3 && < 1.5,
-        time     >= 1.4 && < 1.12,
+        time     >= 1.4 && < 1.14,
         unix     >= 2.5.1 && < 2.8



--- a/libraries/filepath/filepath.cabal
+++ b/libraries/filepath/filepath.cabal
@@ -60,7 +60,7 @@ library
         System.FilePath.Windows
     other-modules:
         System.FilePath.Internal
-    build-depends: base >= 4.9 && < 4.17
+    build-depends: base >= 4.9 && < 4.19
     default-language: Haskell2010
     ghc-options: -Wall


--- a/libraries/ghc-compact/ghc-compact.cabal
+++ b/libraries/ghc-compact/ghc-compact.cabal
@@ -24,7 +24,7 @@ library
   default-language:    Haskell2010

   build-depends:
-                 base       >= 4.9.0 && < 4.17,
+                 base       >= 4.9.0 && < 4.19,
                  ghc-prim   >= 0.5.3 && < 0.9,
                  bytestring >= 0.10.6.0
   ghc-options: -Wall

--- a/libraries/haskeline/haskeline.cabal
+++ b/libraries/haskeline/haskeline.cabal
@@ -48,7 +48,7 @@ flag examples
 library
     default-language: Haskell98
     Build-depends:
-        base >=4.9 && < 4.17, containers>=0.4 && < 0.7,
+        base >=4.9 && < 4.19, containers>=0.4 && < 0.7,
         directory >= 1.1 && < 1.4,
         bytestring >= 0.9 && < 0.12,
         filepath >= 1.2 && < 1.5,

--- a/libraries/hpc/hpc.cabal
+++ b/libraries/hpc/hpc.cabal
@@ -35,11 +35,11 @@ Library
         Trace.Hpc.Reflect

     Build-Depends:
-        base       >= 4.4.1 && < 4.17,
+        base       >= 4.4.1 && < 4.19,
         containers >= 0.4.1 && < 0.7,
         deepseq    >= 1.1   && < 1.5,
         directory  >= 1.1   && < 1.4,
         filepath   >= 1     && < 1.5,
-        time       >= 1.2   && < 1.12
+        time       >= 1.2   && < 1.14
     ghc-options: -Wall


--- a/libraries/parsec/parsec.cabal
+++ b/libraries/parsec/parsec.cabal
@@ -66,7 +66,7 @@ library
         Text.Parsec.String
         Text.ParserCombinators.Parsec.Char
     build-depends:
-        base       >= 4.5.0   && < 4.17,
+        base       >= 4.5.0   && < 4.19,
         mtl        >= 1.1     && < 2.4,
         bytestring >= 0.9     && < 0.12,
         text       >= 1.2.3   && < 1.3 || >=2.0 && <2.1

--- a/libraries/process/process.cabal
+++ b/libraries/process/process.cabal
@@ -69,7 +69,7 @@ library
         System.Process.CommunicationHandle.Internal
     other-modules: System.Process.Common
     c-sources:        cbits/runProcess.c
-    build-depends: base      >= 4.10 && < 4.18,
+    build-depends: base      >= 4.10 && < 4.19,
                    directory >= 1.1 && < 1.4,
                    filepath  >= 1.2 && < 1.5,
                    deepseq   >= 1.1 && < 1.5

--- a/libraries/stm/stm.cabal
+++ b/libraries/stm/stm.cabal
@@ -35,7 +35,7 @@ library
   default-language: Haskell2010
   other-extensions: CPP, DeriveDataTypeable, FlexibleInstances, MagicHash, MultiParamTypeClasses, UnboxedTuples

-  build-depends: base  >= 4.3 && < 4.17,
+  build-depends: base  >= 4.3 && < 4.19,
                  array >= 0.3 && < 0.6
   ghc-options: -Wall


--- a/libraries/terminfo/terminfo.cabal
+++ b/libraries/terminfo/terminfo.cabal
@@ -34,7 +34,7 @@ library
     default-language: Haskell98
     build-depends:
         -- The upper bounds on the integer-gmp and integer-simple bounds are
-        base >= 4.9 && < 4.17
+        base >= 4.9 && < 4.19
     ghc-options: -Wall
     exposed-modules:
         System.Console.Terminfo

--- a/libraries/unix/unix.cabal
+++ b/libraries/unix/unix.cabal
@@ -79,9 +79,9 @@ library
         -- we need to check which platform.

     build-depends:
-        base        >= 4.5     && < 4.17,
+        base        >= 4.5     && < 4.19,
         bytestring  >= 0.9.2   && < 0.12,
-        time        >= 1.2     && < 1.12
+        time        >= 1.2     && < 1.14

     exposed-modules:
         System.Posix
