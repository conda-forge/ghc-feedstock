+    Cabal.registerPackage context

     -- We declare that this rule also produces files matching:
     --   - <root>/stage<N>/lib/<arch>-<os>-ghc-<version>/*libHS<pkgid>*
@@ -191,7 +205,24 @@
 copyConf rs context@Context {..} conf = do
     depPkgIds <- fmap stdOutToPkgIds . askWithResources rs $
         target context (GhcPkg Dependencies stage) [pkgName package] []
-    need =<< mapM (\pkgId -> packageDbPath stage <&> (-/- pkgId <.> "conf")) depPkgIds
+    -- Remap deps to source versions and filter out RTS (not registered at Stage0)
+    srcPackages <- stagePackages Stage0
+    remappedDepPkgIds <- fmap catMaybes . forM depPkgIds $ \depPkgId -> do
+        let depName = case parseCabalName depPkgId of
+                        Left _ -> depPkgId
+                        Right (name, _) -> name
+        if depName == "rts" then
+            return Nothing  -- Skip RTS dependency
+        else case filter (\p -> pkgName p == depName) srcPackages of
+            (srcPkg:_) -> fmap Just $ pkgIdentifier srcPkg
+            []         -> return $ Just depPkgId
+    need =<< mapM (\pkgId -> packageDbPath stage <&> (-/- pkgId <.> "conf")) remappedDepPkgIds
+
+    -- Build remapping table for fixing .conf file
+    versionRemappings <- fmap concat . forM srcPackages $ \srcPkg -> do
+        srcPkgId <- pkgIdentifier srcPkg
+        return [(pkgName srcPkg, srcPkgId)]
+
     -- We should unregister if the file exists since @ghc-pkg@ will complain
     -- about existing package: https://github.com/snowleopard/hadrian/issues/543.
     -- Also, we don't always do the unregistration + registration to avoid
@@ -202,12 +233,45 @@
     unlessM (liftIO $ IO.doesFileExist conf) $ do
         buildWithResources rs $
             target context (GhcPkg Unregister stage) [pkgName package] []
-        buildWithResources rs $
-            target context (GhcPkg Copy stage) [pkgName package] [conf]
+        -- Get package from bootstrap with expanded paths, fix deps, register
+        pkgDbPath <- packageDbPath stage
+        ghcPkgPath <- builderPath (GhcPkg Init stage)
+        -- Use --expand-pkgroot to get absolute paths to bootstrap's libs
+        Stdout pkgDesc <- cmd [ghcPkgPath] ["--expand-pkgroot", "--no-user-package-db"
+                                           , "describe", pkgName package]
+        let fixedPkgDesc = fixDependencyVersions versionRemappings pkgDesc
+        liftIO $ writeFile conf fixedPkgDesc
+        -- Use 'update' for idempotency in parallel builds
+        cmd_ [ghcPkgPath] ["--no-user-package-db", "--global-package-db", pkgDbPath
+                          , "update", conf, "-v0", "--force"]
   where
     stdOutToPkgIds :: String -> [String]
     stdOutToPkgIds = drop 1 . concatMap words . lines

+-- | Fix dependency versions in package description.
+-- Remaps bootstrap versions to source versions and removes rts dependency.
+fixDependencyVersions :: [(String, String)] -> String -> String
+fixDependencyVersions remappings desc = unlines $ map fixLine $ lines desc
+  where
+    fixLine line
+        | "depends:" `isPrefixOf` trimmedLine = fixDependsLine line
+        | otherwise = line
+      where trimmedLine = dropWhile (== ' ') line
+    fixDependsLine line =
+        let (prefix, rest) = break (== ':') line
+            deps = drop 1 rest
+            fixed = filter (not . isRtsDep) $ map fixDep $ words deps
+        in prefix ++ ": " ++ unwords fixed
+    isRtsDep dep = case parseCabalName dep of
+        Right (name, _) -> name == "rts"
+        Left _ -> "rts-" `isPrefixOf` dep  -- Fallback heuristic
+    fixDep dep = case parseCabalName dep of
+        Right (name, _) -> case lookup name remappings of
+            Just srcPkgId -> srcPkgId
+            Nothing -> dep
+        Left _ -> dep
+    isPrefixOf needle haystack = take (length needle) haystack == needle
+
 getPackageNameFromConfFile :: FilePath -> Action String
 getPackageNameFromConfFile conf
     = fromStdout <$> cmd ["ghc-pkg", "--simple-output"
