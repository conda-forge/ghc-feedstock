-        let (prefix, deps) = break (== ':') line
-            depsAfterColon = drop 1 deps  -- Remove the ':'
-        in prefix ++ ":" ++ unwords (map fixDep $ words depsAfterColon)
+        let (prefix, rest) = break (== ':') line
