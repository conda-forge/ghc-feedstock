From: Claude <noreply@anthropic.com>
Subject: [PATCH] Stage-aware version remapping for cross-bootstrap (Fix #23)

Fix #22 incorrectly applied version remapping at Stage0, causing Stage0
utilities (genprimopcode, hsc2hs) to fail linking with undefined symbols
like `stg_unpack_cstring_info` and `ghczmprim_*_closure`.

Key insight: Stage0 utilities are CONSUMERS of bootstrap packages and must
link against bootstrap's RTS/base/ghc-prim. Only Stage1 libraries should
use source package versions.

Fix #23: Only remap dependency versions at Stage1, not Stage0.

--- a/hadrian/src/Rules/Register.hs	2025-12-23 10:57:32.489869887 -0600
+++ b/hadrian/src/Rules/Register.hs	2025-12-23 11:00:40.853416625 -0600
@@ -27,6 +27,18 @@
 import qualified Hadrian.Haskell.Cabal.Parse as Cabal
 import qualified System.Directory            as IO
 
+-- | Stage1 core library names for version remapping during cross-bootstrap.
+-- When bootstrapping with a newer GHC (e.g., 9.6.7 -> 9.2.8), dependency
+-- versions from cabalDependencies reflect bootstrap, not source.
+--
+-- FIX #23: Only remap at Stage1. Stage0 utilities link against bootstrap.
+stage1CoreLibNames :: [String]
+stage1CoreLibNames =
+    [ "base", "ghc-prim", "ghc-bignum", "integer-gmp"
+    , "array", "deepseq", "pretty", "template-haskell"
+    , "ghc-boot-th", "ghc-heap"
+    ]
+
 -- * Configuring
 
 -- | Configure a package and build its @setup-config@ file, as well as files in
@@ -118,7 +130,26 @@
 buildConf _ context@Context {..} _conf = do
     depPkgIds <- cabalDependencies context
     ensureConfigured context
-    need =<< mapM (\pkgId -> packageDbPath stage <&> (-/- pkgId <.> "conf")) depPkgIds
+    -- FIX #23: Stage-aware version remapping for cross-bootstrap.
+    -- Stage0 utilities must use BOOTSTRAP package versions (they link against bootstrap).
+    -- Stage1 libraries use SOURCE package versions (they are built from source).
+    remappedDepPkgIds <- case stage of
+        Stage0 -> return depPkgIds  -- Keep bootstrap versions at Stage0
+        _ -> do
+            -- At Stage1+, remap dependency versions to source versions
+            stage0Pkgs <- stagePackages Stage0
+            forM depPkgIds $ \depPkgId -> do
+                let depName = case parseCabalName depPkgId of
+                                Left _ -> depPkgId
+                                Right (name, _) -> name
+                -- Check if package exists in Stage0 packages
+                case filter (\p -> pkgName p == depName) stage0Pkgs of
+                    (srcPkg:_) -> pkgIdentifier srcPkg
+                    [] -> -- Check Stage1 core libs (static list, since stagePackages Stage1 is empty here)
+                        if depName `elem` stage1CoreLibNames
+                        then pkgIdentifier (unsafeFindPackageByName depName)
+                        else return depPkgId  -- Keep bootstrap version for true boot packages
+    need =<< mapM (\pkgId -> packageDbPath stage <&> (-/- pkgId <.> "conf")) remappedDepPkgIds
 
     ways <- interpretInContext context (getLibraryWays <> if package == rts then getRtsWays else mempty)
     need =<< concatMapM (libraryTargets True) [ context { way = w } | w <- ways ]
