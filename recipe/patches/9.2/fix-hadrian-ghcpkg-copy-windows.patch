From: Claude <noreply@anthropic.com>
Subject: [PATCH] Fix Stage0 package registration for mixed bootstrap/source deps

When using a newer bootstrap GHC (e.g., 9.6.7 to build 9.2.8), copyConf
queries bootstrap's package database for dependencies. These dependencies
have bootstrap version numbers (e.g., template-haskell-2.20.0.0).

If a dependency package exists in source with a different version (e.g.,
template-haskell-2.18.0.0), we must use the source version, not the
bootstrap version. Otherwise the build fails because there's no
template-haskell-2.20.0.0.conf in our Stage0 package database.

This patch makes three changes:

1. In registerPackageRules: For packages in source, NEVER call copyConf.
   If wrong version requested, error explicitly to help debug.
   IMPORTANT: RTS is special - it's not in stagePackages but must be built
   from source, so we never use copyConf for it.

2. In copyConf: After getting dependencies from bootstrap, remap any
   package that exists in source to use the source version instead.
   This ensures copyConf needs the right .conf files.

3. In copyConf: When copying a package from bootstrap, also fix the
   dependency versions in the .conf file content. Uses ghc-pkg describe
   to get the package info, patches the depends: field to use source
   versions, then updates the package database (using 'update' instead
   of 'register' for idempotency in parallel builds).

--- a/hadrian/src/Rules/Register.hs
+++ b/hadrian/src/Rules/Register.hs
@@ -107,7 +107,27 @@ registerPackageRules rs stage = do

         when (pkg == compiler) $ need =<< ghcLibDeps stage

-        isBoot <- (pkg `notElem`) <$> stagePackages Stage0
+        -- Determine if this is a boot package (not in source).
+        -- CRITICAL: For packages that exist in source, we must NEVER call
+        -- copyConf, even if a different version is requested. This is because
+        -- copyConf unregisters by package NAME (not version), which would
+        -- remove the source version and cause dependency resolution failures.
+        --
+        -- SPECIAL CASE: RTS is not in stagePackages but MUST be built from
+        -- source (it has its own build rules). Never use copyConf for RTS.
+        notInSource <- (pkg `notElem`) <$> stagePackages Stage0
+        -- Note: pkgName here is a local String variable from getPackageNameFromConfFile
+        let isRts = pkgName == "rts"
+        srcPkgId <- pkgIdentifier pkg
+        let confPkgId = takeBaseName conf
+            versionMismatch = confPkgId /= srcPkgId
+            -- Only use copyConf for packages truly not in source AND not RTS
+            isBoot = notInSource && not isRts
+
+        -- If source package but wrong version requested, error explicitly
+        -- (Skip this check for RTS since it is built separately)
+        when (not notInSource && versionMismatch && not isRts) $
+            error $ "Version mismatch: requested " ++ confPkgId ++ " but source has " ++ srcPkgId

         let ctx = Context stage pkg vanilla
         case stage of
@@ -164,7 +184,26 @@ registerPackageRules rs stage = do
 copyConf rs context@Context {..} conf = do
     depPkgIds <- fmap stdOutToPkgIds . askWithResources rs $
         target context (GhcPkg Dependencies stage) [pkgName package] []
-    need =<< mapM (\pkgId -> packageDbPath stage <&> (-/- pkgId <.> "conf")) depPkgIds
+    -- Remap dependency package-ids to source versions when the package exists
+    -- in source. This is needed because bootstrap dependencies have bootstrap
+    -- versions (e.g., template-haskell-2.20.0.0) but we need source versions
+    -- (e.g., template-haskell-2.18.0.0).
+    srcPackages <- stagePackages Stage0
+    remappedDepPkgIds <- forM depPkgIds $ \depPkgId -> do
+        let depName = case parseCabalName depPkgId of
+                        Left _ -> depPkgId  -- Fallback to original if parse fails
+                        Right (name, _) -> name
+        case filter (\p -> pkgName p == depName) srcPackages of
+            (srcPkg:_) -> pkgIdentifier srcPkg  -- Use source version
+            []         -> return depPkgId       -- Keep bootstrap version
+    need =<< mapM (\pkgId -> packageDbPath stage <&> (-/- pkgId <.> "conf")) remappedDepPkgIds
+
+    -- Build version remapping table for fixing .conf file dependencies
+    versionRemappings <- fmap concat . forM srcPackages $ \srcPkg -> do
+        srcPkgId <- pkgIdentifier srcPkg
+        let srcName = pkgName srcPkg
+        return [(srcName, srcPkgId)]
+
     -- We should unregister if the file exists since @ghc-pkg@ will complain
     -- about existing package: https://github.com/snowleopard/hadrian/issues/543.
     -- Also, we don't always do the unregistration + registration to avoid
@@ -175,12 +214,45 @@ copyConf rs context@Context {..} conf = do
     unlessM (liftIO $ IO.doesFileExist conf) $ do
         buildWithResources rs $
             target context (GhcPkg Unregister stage) [pkgName package] []
-        buildWithResources rs $
-            target context (GhcPkg Copy stage) [pkgName package] [conf]
+        -- Get package description from bootstrap, fix dependency versions, register
+        pkgDbPath <- packageDbPath stage
+        ghcPkgPath <- builderPath (GhcPkg Init stage)
+        -- Get the package description from bootstrap
+        Stdout pkgDesc <- cmd [ghcPkgPath] ["describe", pkgName package]
+        -- Fix dependency versions in the description
+        let fixedPkgDesc = fixDependencyVersions versionRemappings pkgDesc
+        -- Write fixed description to conf file and update package database.
+        -- NOTE: Use 'update' instead of 'register' to make this idempotent.
+        -- Multiple parallel tasks may try to register the same boot package
+        -- (race condition). 'update' will succeed even if package exists.
+        liftIO $ writeFile conf fixedPkgDesc
+        cmd_ [ghcPkgPath] ["--no-user-package-db", "--global-package-db", pkgDbPath
+                          , "update", conf, "-v0", "--force"]
   where
     stdOutToPkgIds :: String -> [String]
     stdOutToPkgIds = drop 1 . concatMap words . lines

+-- | Fix dependency versions in a package description.
+-- Replaces bootstrap package versions with source package versions in the
+-- 'depends:' field. For example, 'template-haskell-2.20.0.0' becomes
+-- 'template-haskell-2.18.0.0' if template-haskell is in source with that version.
+fixDependencyVersions :: [(String, String)] -> String -> String
+fixDependencyVersions remappings desc = unlines $ map fixLine $ lines desc
+  where
+    fixLine line
+        | "depends:" `isPrefixOf` (dropWhile (== ' ') line) = fixDependsLine line
+        | otherwise = line
+    fixDependsLine line =
+        let (prefix, deps) = break (== ':') line
+            depsAfterColon = drop 1 deps  -- Remove the ':'
+        in prefix ++ ":" ++ unwords (map fixDep $ words depsAfterColon)
+    fixDep dep = case parseCabalName dep of
+        Left _ -> dep  -- Cannot parse, leave unchanged
+        Right (name, _) -> case lookup name remappings of
+            Just srcPkgId -> srcPkgId  -- Replace with source version
+            Nothing -> dep  -- Not in source, keep bootstrap version
+    isPrefixOf needle haystack = take (length needle) haystack == needle
+
 getPackageNameFromConfFile :: FilePath -> Action String
 getPackageNameFromConfFile conf
     | takeBaseName conf == "rts" = return "rts"
