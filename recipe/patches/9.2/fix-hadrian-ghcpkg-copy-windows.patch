             need [buildP -/- "include/ghc-gmp.h"]
-        deps <- contextDependencies ctx
-        needLibrary deps
-        -- For Stage0, also ensure dependency packages are registered in the
-        -- package database before configuring. This is needed when using a
-        -- different bootstrap GHC version, as Cabal.configurePackage checks
-        -- version constraints against the package database.
-        when (stage == Stage0) $ do
-            dbPath <- packageDbPath stage
-            depPkgIds <- mapM (pkgIdentifier . package) deps
-            need [dbPath -/- pkgId <.> "conf" | pkgId <- depPkgIds]
+        needLibrary =<< contextDependencies ctx
         Cabal.configurePackage ctx

     root -/- "**/autogen/cabal_macros.h" %> \out -> do
@@ -116,12 +108,52 @@

         when (pkg == compiler) $ need =<< ghcLibDeps stage

-        isBoot <- (pkg `notElem`) <$> stagePackages Stage0
+        -- Determine if this is a boot package (not in source).
+        -- CRITICAL: For packages in source, NEVER call copyConf even if a
+        -- different version is requested (copyConf unregisters by NAME).
+        --
+        -- SPECIAL CASE: RTS at Stage0 must be SKIPPED entirely!
+        -- Stage0 utilities link against bootstrap libraries which expect
+        -- bootstrap's RTS symbols. By not registering our RTS, bootstrap
+        -- GHC falls back to its global DB with compatible RTS.
+        notInSource <- (pkg `notElem`) <$> stagePackages Stage0
+        let isRts = pkgName pkg == "rts"
+            skipRtsAtStage0 = isRts && stage == Stage0
+        srcPkgId <- pkgIdentifier pkg
+        let confPkgId = takeBaseName conf
+            versionMismatch = confPkgId /= srcPkgId
+            isBoot = notInSource
+
+        -- Error on version mismatch for source packages (except skipped RTS)
+        when (not notInSource && versionMismatch && not skipRtsAtStage0) $
+            error $ "Version mismatch: " ++ confPkgId ++ " vs " ++ srcPkgId
+
+        -- Skip RTS at Stage0 - use bootstrap's RTS from global DB
+        when skipRtsAtStage0 $ do
+            liftIO $ putStrLn "# Skipping RTS registration (using bootstrap RTS)"
+            -- But we still need to create the .conf file for other packages
+            -- that depend on RTS. Copy bootstrap's RTS with absolute paths.
+            pkgDbPath <- packageDbPath stage
+            ghcPkgPath <- builderPath (GhcPkg Init stage)
+            -- Get bootstrap's RTS with expanded paths (converts ${pkgroot})
+            Stdout rtsDesc <- cmd [ghcPkgPath]
+                ["--expand-pkgroot", "--no-user-package-db", "describe", "rts"]
+            liftIO $ writeFile conf rtsDesc
+            -- Register in Stage0 package database
+            cmd_ [ghcPkgPath]
+                ["--no-user-package-db", "--global-package-db", pkgDbPath
+                , "update", conf, "-v0", "--force"]
+            liftIO $ putStrLn $ "# Copied bootstrap RTS to " ++ conf
+            return ()

         let ctx = Context stage pkg vanilla
         case stage of
-            Stage0 | isBoot -> copyConf  rs ctx conf
-            _               -> buildConf rs ctx conf
+            Stage0 | isBoot && not skipRtsAtStage0 -> do
+                -- See Note [Inplace vs Final package databases]
+                copyConf rs ctx conf
+            _ -> do
+                unless skipRtsAtStage0 $
+                    buildConf rs ctx conf

