From: conda-forge
Subject: [PATCH] Fix ghc-pkg copy for cross-version bootstrap on Windows (Fix #18)

When using GHC 9.6.7 to build GHC 9.2.8 on Windows, several issues arise:

1. RTS ABI incompatibility - Stage0 utilities link against bootstrap libs
   which expect bootstrap's RTS symbols, not our locally-built RTS.

2. Dependency version mismatch - Bootstrap deps have bootstrap versions
   (e.g., template-haskell-2.20.0.0) but source has different versions
   (e.g., template-haskell-2.18.0.0). Shake looks for wrong version's .conf.

3. Package path resolution - ${pkgroot} in .conf files resolves incorrectly.

4. Stdin piping issues on Windows/MSYS2 with ghc-pkg register.

This patch:
- Copies bootstrap's RTS to Stage0 package database with absolute paths
- Remaps dependency versions from bootstrap to source before calling need
- Filters RTS from dependencies in other packages (they get it via inheritance)
- Uses --expand-pkgroot to get absolute paths for all copied packages
- Uses ghc-pkg update (file-based) instead of register (stdin-based)
- Rewrites depends: field in .conf files with correct source versions

Fix #18: The linker needs RTS symbols when linking Stage0 utilities. GHC
does NOT automatically fall back to its global package database for library
resolution. We must copy bootstrap's RTS (with expanded absolute paths) into
Stage0's package database so the linker can find libHSrts.a.

--- a/hadrian/src/Rules/Register.hs
+++ b/hadrian/src/Rules/Register.hs
@@ -15,6 +15,8 @@
 import Settings
 import Target
 import Utilities
+import Data.List (isPrefixOf)
+import Data.Maybe (catMaybes)

 import Hadrian.Haskell.Cabal.Type
 import qualified Text.Parsec      as Parsec
@@ -105,14 +107,26 @@
         pkgName <- getPackageNameFromConfFile conf
         let pkg = unsafeFindPackageByName pkgName

+        -- Handle RTS specially at Stage0 for cross-version bootstrap.
+        -- Stage0 utilities link against bootstrap libs expecting bootstrap's
+        -- RTS symbols. We must copy bootstrap's RTS (with absolute paths) to
+        -- Stage0 package database so the linker can find libHSrts.a.
+        -- GHC does NOT fall back to global DB for library resolution.
+        let copyRtsAtStage0 = stage == Stage0 && pkg == rts
+        when copyRtsAtStage0 $ do
+            liftIO $ putStrLn "# Copying bootstrap RTS to Stage0 (for linker compatibility)"
+            pkgDbPath <- packageDbPath stage
+            ghcPkgPath <- builderPath (GhcPkg Init stage)
+            -- Get bootstrap's RTS description with absolute paths
+            Stdout rtsDesc <- cmd [ghcPkgPath]
+                ["--expand-pkgroot", "--no-user-package-db", "describe", "rts"]
+            liftIO $ writeFile conf rtsDesc
+            -- Register in Stage0 package database
+            cmd_ [ghcPkgPath]
+                ["--no-user-package-db", "--global-package-db", pkgDbPath
+                , "update", conf, "-v0", "--force"]
+            liftIO $ putStrLn $ "# Registered bootstrap RTS at " ++ conf
+
         when (pkg == compiler) $ need =<< ghcLibDeps stage

         isBoot <- (pkg `notElem`) <$> stagePackages Stage0
-
         let ctx = Context stage pkg vanilla
         case stage of
-            Stage0 | isBoot -> copyConf  rs ctx conf
-            _               -> buildConf rs ctx conf
+            -- RTS at Stage0 is handled above (copy bootstrap's RTS)
+            _ | copyRtsAtStage0 -> return ()
+            Stage0 | isBoot -> copyConf rs ctx conf
+            _ -> buildConf rs ctx conf

 buildConf :: [(Resource, Int)] -> Context -> FilePath -> Action ()
 buildConf _ context@Context {..} _conf = do
@@ -164,7 +178,26 @@
 copyConf rs context@Context {..} conf = do
     depPkgIds <- fmap stdOutToPkgIds . askWithResources rs $
         target context (GhcPkg Dependencies stage) [pkgName package] []
-    need =<< mapM (\pkgId -> packageDbPath stage <&> (-/- pkgId <.> "conf")) depPkgIds
+    -- Remap bootstrap dependency versions to source versions and filter RTS.
+    -- Bootstrap deps like template-haskell-2.20.0.0 must become source versions
+    -- like template-haskell-2.18.0.0, otherwise Shake will try to build the
+    -- wrong version's .conf file and fail.
+    srcPackages <- stagePackages Stage0
+    remappedDeps <- fmap catMaybes . forM depPkgIds $ \depPkgId -> do
+        let depName = case parseCabalName depPkgId of
+                Left _ -> depPkgId  -- Fallback to original if parse fails
+                Right (name, _) -> name
+        -- Filter RTS from Shake dependencies (handled specially, not via copyConf)
+        if depName == "rts" || "rts-" `isPrefixOf` depPkgId
+            then return Nothing
+            else case filter (\p -> pkgName p == depName) srcPackages of
+                -- Package is in source: use source version
+                (srcPkg:_) -> do
+                    srcPkgId <- pkgIdentifier srcPkg
+                    return (Just srcPkgId)
+                -- Package not in source: keep bootstrap version (will be copied)
+                [] -> return (Just depPkgId)
+    need =<< mapM (\pkgId -> packageDbPath stage <&> (-/- pkgId <.> "conf")) remappedDeps
     -- We should unregister if the file exists since @ghc-pkg@ will complain
     -- about existing package: https://github.com/snowleopard/hadrian/issues/543.
     -- Also, we don't always do the unregistration + registration to avoid
@@ -175,11 +208,42 @@
     unlessM (liftIO $ IO.doesFileExist conf) $ do
         buildWithResources rs $
             target context (GhcPkg Unregister stage) [pkgName package] []
-        buildWithResources rs $
-            target context (GhcPkg Copy stage) [pkgName package] [conf]
+        -- Get package description with expanded paths, fix versions, register
+        pkgDbPath <- packageDbPath stage
+        ghcPkgPath <- builderPath (GhcPkg Init stage)
+        -- --expand-pkgroot converts ${pkgroot} to absolute bootstrap paths
+        Stdout pkgDesc <- cmd [ghcPkgPath]
+            ["--expand-pkgroot", "--no-user-package-db", "describe", pkgName package]
+        -- Collect version remappings for fixing .conf file
+        remapList <- forM srcPackages $ \srcPkg -> do
+            srcPkgId <- pkgIdentifier srcPkg
+            return (pkgName srcPkg, srcPkgId)
+        -- Fix dependency versions in the description
+        let fixedPkgDesc = fixDependencyVersions remapList pkgDesc
+        liftIO $ writeFile conf fixedPkgDesc
+        -- Use 'update' (file-based) not 'register -' (stdin) for Windows compat
+        cmd_ [ghcPkgPath]
+            ["--no-user-package-db", "--global-package-db", pkgDbPath
+            , "update", conf, "-v0", "--force"]
   where
     stdOutToPkgIds :: String -> [String]
     stdOutToPkgIds = drop 1 . concatMap words . lines
+    -- Fix dependency versions in a package description.
+    -- Replaces bootstrap package versions with source versions and filters rts.
+    fixDependencyVersions :: [(String, String)] -> String -> String
+    fixDependencyVersions remappings desc = unlines $ map fixLine $ lines desc
+      where
+        fixLine line
+            | "depends:" `isPrefixOf` (dropWhile (== ' ') line) = fixDependsLine line
+            | otherwise = line
+        fixDependsLine line =
+            let (prefix, rest) = break (== ':') line
+                deps = drop 1 rest
+                -- Keep rts in depends (bootstrap's RTS is now registered in Stage0)
+                fixed = map fixDep $ words deps
+            in prefix ++ ": " ++ unwords fixed
+        fixDep dep = case parseCabalName dep of
+            Right (name, _) -> maybe dep id $ lookup name remappings
+            Left _ -> dep

 getPackageNameFromConfFile :: FilePath -> Action String
 getPackageNameFromConfFile conf
