From: Claude <noreply@anthropic.com>
Subject: [PATCH] Fix ghc-pkg copy stdin piping on Windows

On Windows with MSYS2/cmd.exe, stdin piping from ghc-pkg describe to
ghc-pkg register is unreliable. This causes random failures when copying
packages from the bootstrap GHC to Stage0's package database.

The fix writes the package description to a temp file and passes the
file path to ghc-pkg register instead of using stdin with "-".

Uses withFile to ensure the file handle is properly closed before
ghc-pkg reads it (critical on Windows where file locking is strict).

See: https://github.com/haskell/process/issues/273

diff --git a/hadrian/src/Builder.hs b/hadrian/src/Builder.hs
--- a/hadrian/src/Builder.hs
+++ b/hadrian/src/Builder.hs
@@ -30,7 +30,7 @@
 import Hadrian.Utilities
 import Oracles.Setting (bashPath)
 import System.Exit
-import System.IO (stderr)
+import System.IO (stderr, withFile, IOMode(..), hPutStr, hFlush)

 import Base
 import Context
@@ -336,13 +336,21 @@
                     Stdout stdout <- cmd' (Stdin stdin) [path] buildArgs
                     writeFileChanged output stdout

+                -- On Windows, stdin piping through MSYS2/cmd.exe is unreliable.
+                -- Write package description to a temp file instead of stdin.
+                -- Use withFile to ensure handle is closed before ghc-pkg reads.
+                -- See: https://github.com/haskell/process/issues/273
                 GhcPkg Copy _ -> do
                     Stdout pkgDesc <- cmd' [path]
                       [ "--expand-pkgroot"
                       , "--no-user-package-db"
                       , "describe"
                       , input -- the package name
                       ]
-                    cmd' (Stdin pkgDesc) [path] (buildArgs ++ ["-"])
+                    -- Write to temp file with explicit flush and close
+                    let tmpFile = output <.> "pkg-desc"
+                    liftIO $ withFile tmpFile WriteMode $ \h -> do
+                      hPutStr h pkgDesc
+                      hFlush h
+                    cmd' [path] (buildArgs ++ [tmpFile])

                 GhcPkg Unregister _ -> do
                     Exit _ <- cmd' echo [path] (buildArgs ++ [input])
