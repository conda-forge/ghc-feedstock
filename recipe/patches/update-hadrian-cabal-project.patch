--- a/hadrian/cabal.project
+++ b/hadrian/cabal.project
@@ -1,9 +1,17 @@
 packages: ./

--- This essentially freezes the build plan for hadrian
-index-state: 2022-01-22T11:45:54Z
+-- Updated index-state to get packages compatible with base-4.18
+-- (needed when using newer ghc-bootstrap)
+index-state: 2024-01-01T00:00:00Z

 -- N.B. Compile with -O0 since this is not a performance-critical executable
 -- and the Cabal takes nearly twice as long to build with -O1. See #16817.
 package Cabal
   optimization: False
+
+-- Allow newer versions ONLY for building Hadrian itself
+-- GHC libraries will be built from source with their own versions
+allow-newer:
+  hadrian:base,
+  hadrian:Cabal,
+  hadrian:unix
+
+-- Build Hadrian and all dependencies statically
+-- (We don't install Hadrian, so no need for dynamic libraries)
+package *
+  shared: False
+  executable-dynamic: False
