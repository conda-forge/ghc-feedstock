Skip documentation build in binary-dist when --docs=none is passed.

The binary-dist rule unconditionally calls `need ["docs"]` for non-cross
builds, ignoring the --docs=none flag. This patch makes it respect the
--docs flag by checking if doctargets is empty.

Fixes build failures when documentation tools (Sphinx, Xelatex) are unavailable.

--- a/hadrian/src/Rules/BinaryDist.hs
+++ b/hadrian/src/Rules/BinaryDist.hs
@@ -5,6 +5,8 @@ import Hadrian.Haskell.Cabal
 
 import CommandLine
 import Context
+import qualified Data.Set as Set
+import Flavour
 import Expression
 import Oracles.Setting
 import Oracles.Flag
@@ -214,7 +216,11 @@ bindistRules = do
         unless windowsHost $
             removeFile (bindistFilesDir -/- "lib" -/- "settings")
 
-        unless cross $ need ["docs"]
+        -- Only build docs if not cross-compiling AND docs are requested
+        -- (respects --docs=none flag via ghcDocs from flavour)
+        doctargets <- ghcDocs =<< flavour
+        let wantDocs = not (Set.null doctargets)
+        unless (cross || not wantDocs) $ need ["docs"]
 
         -- TODO: we should only embed the docs that have been generated
         -- depending on the current settings (flavours' "ghcDocs" field and
